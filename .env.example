# LLM (Ollama — optional, game works without it)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3.1

# App
POKEFORGE_DEFAULT_LOCALE=fr-FR

# Supabase (scripts serveur uniquement — NE PAS mettre dans game/config.js)
# La clé anon va dans game/config.js (côté client)
# La service_role va ici uniquement pour les scripts admin
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...jamais_cote_client...
